{% extends 'emails/layout.html.twig' %}

{% block title %}Appointment Cancelled{% endblock %}

{% block content %}
  <h2 style="margin:0 0 16px;font-size:20px;color:#1e3a5f;">Your appointment has been cancelled</h2>
  <p>Hello <strong>{{ clientFirstName }}</strong>,</p>
  <p>We're sorry, but the following appointment has been cancelled:</p>
  <table style="width:100%;border-collapse:collapse;">
    <tr><td style="padding:6px 0;color:#6b7280;">Service</td><td>{{ serviceName }}</td></tr>
    <tr><td style="padding:6px 0;color:#6b7280;">Time</td><td>{{ startTime|date('H:i, l, d/m/Y') }}</td></tr>
    <tr><td style="padding:6px 0;color:#6b7280;">Shop</td><td>{{ shopName }}</td></tr>
  </table>
  {% if shopPhone %}
    <p style="margin-top:24px;">
      Please contact us to rebook: <strong>{{ shopPhone }}</strong>
    </p>
  {% endif %}
{% endblock %}
