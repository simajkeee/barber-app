<!DOCTYPE html>
<html lang="en">
<body style="font-family: sans-serif; color: #333; max-width: 600px; margin: 0 auto; padding: 20px;">
  <h2>Your appointment has been cancelled</h2>
  <p>Hello {{ clientFirstName }},</p>
  <p>We're sorry, but the following appointment has been cancelled:</p>
  <table style="width: 100%; border-collapse: collapse;">
    <tr><td style="padding: 6px 0; color: #666;">Service</td><td>{{ serviceName }}</td></tr>
    <tr><td style="padding: 6px 0; color: #666;">Time</td><td>{{ startTime|date('H:i, l, d/m/Y') }}</td></tr>
    <tr><td style="padding: 6px 0; color: #666;">Shop</td><td>{{ shopName }}</td></tr>
  </table>
  <p style="margin-top: 24px;">
    Please contact us to rebook: <strong>{{ shopPhone }}</strong>
  </p>
</body>
</html>
