<!DOCTYPE html>
<html lang="en">
<body style="font-family: sans-serif; color: #333; max-width: 600px; margin: 0 auto; padding: 20px;">
  <h2>You have a new appointment!</h2>
  <table style="width: 100%; border-collapse: collapse;">
    <tr><td style="padding: 6px 0; color: #666;">Client</td><td>{{ clientFullName }}</td></tr>
    <tr><td style="padding: 6px 0; color: #666;">Phone</td><td>{{ clientPhone }}</td></tr>
    <tr><td style="padding: 6px 0; color: #666;">Service</td><td>{{ serviceName }} ({{ durationMinutes }} minutes)</td></tr>
    <tr><td style="padding: 6px 0; color: #666;">Time</td><td>{{ startTime|date('H:i, l, d/m/Y', false) }}</td></tr>
    <tr><td style="padding: 6px 0; color: #666;">Price</td><td>{{ price|number_format(0, ',', '.') }}đ</td></tr>
    {% if notes %}<tr><td style="padding: 6px 0; color: #666;">Notes</td><td>{{ notes }}</td></tr>{% endif %}
  </table>
</body>
</html>
