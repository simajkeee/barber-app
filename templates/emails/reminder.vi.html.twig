<!DOCTYPE html>
<html lang="vi">
<body style="font-family: sans-serif; color: #333; max-width: 600px; margin: 0 auto; padding: 20px;">
  <h2>Nhắc lịch hẹn</h2>
  <p>Xin chào {{ clientFirstName }},</p>
  <p>{{ messageText }}</p>
  {% if shopPhone %}
  <p>Liên hệ: {{ shopPhone }}</p>
  {% endif %}
  <p style="margin-top: 24px;">{{ shopName }}</p>
  <hr style="margin-top: 32px; border: none; border-top: 1px solid #ddd;">
  <p style="font-size: 12px; color: #999;">
    <a href="{{ optOutUrl }}" style="color: #999;">Để không nhận email nhắc hẹn nữa, click vào đây.</a>
  </p>
</body>
</html>
