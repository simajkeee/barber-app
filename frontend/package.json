{
  "name": "barber-app-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npx nuxi cleanup && NODE_OPTIONS=--max-old-space-size=4096 node node_modules/nuxt/bin/nuxt.mjs dev",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 node node_modules/nuxt/bin/nuxt.mjs build",
    "generate": "NODE_OPTIONS=--max-old-space-size=4096 node node_modules/nuxt/bin/nuxt.mjs generate",
    "preview": "node --import ./.output/server/sentry.server.config.mjs ./.output/server/index.mjs",
    "postinstall": "nuxt prepare",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "test": "node --max-old-space-size=4096 node_modules/.bin/vitest run",
    "test:watch": "node --max-old-space-size=4096 node_modules/.bin/vitest",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@pinia/nuxt": "^0.9.0",
    "@sentry/nuxt": "^10.46.0",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/nuxt": "^12.0.0",
    "nuxt": "^3.16.0",
    "pinia": "^2.2.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.0",
    "vue-sonner": "^1.3.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.0",
    "@nuxtjs/i18n": "^9.2.0",
    "@nuxtjs/robots": "^5.2.0",
    "@nuxtjs/sitemap": "^7.2.0",
    "@nuxtjs/tailwindcss": "^6.13.0",
    "@pinia/testing": "^0.1.6",
    "@vite-pwa/nuxt": "^0.10.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "happy-dom": "^20.8.3",
    "nuxt-schema-org": "^4.1.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.6"
  },
  "overrides": {
    "@vercel/nft": "^0.27.4"
  }
}
